{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": true,
    "source.organizeImports": true, // organize imports on save
    "source.removeUnusedImports": true // Removes unused imports only
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode" // prettier for javascript
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode" // prettier for javascriptreact
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode" // prettier for typescript
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode" // prettier for typescriptreact
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
